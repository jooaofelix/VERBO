# Configuração do projeto Firebase (Authentication + Firestore apenas —
# esta versão gratuita não usa Firebase Storage nem Firebase Functions).
# Encontre estes valores em: Console do Firebase → Configurações do projeto →
# Seus apps → app Web (ícone </>). Nenhum destes valores é secreto — eles
# identificam o projeto, não concedem acesso por si só (a segurança real
# vem de firestore.rules e da verificação do ID token no Worker).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL do Cloudflare Worker que roda a análise (Workers AI). Em produção,
# algo como https://verbo-cancao-worker.SEU-SUBDOMINIO.workers.dev — ou o
# domínio customizado que você configurar. Em desenvolvimento local, aponte
# para `wrangler dev` (padrão http://127.0.0.1:8787).
VITE_WORKER_URL=http://127.0.0.1:8787

# Defina como "true" para apontar Auth/Firestore para o Firebase Emulator
# Suite local (firebase emulators:start) em vez do projeto de produção.
VITE_USE_FIREBASE_EMULATORS=false

# Nenhuma chave de IA é necessária aqui: a análise roda via Cloudflare
# Workers AI (binding "AI" no wrangler.jsonc do Worker), sem chave de API.
