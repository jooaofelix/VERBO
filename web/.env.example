# Configuração do projeto Firebase (Authentication + Firestore + Storage).
# Encontre estes valores em: Console do Firebase → Configurações do projeto →
# Seus apps → app Web (ícone </>). Nenhum destes valores é secreto — eles
# identificam o projeto, não concedem acesso por si só (a segurança real
# vem de firestore.rules e storage.rules).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Região onde as Cloud Functions foram publicadas (padrão: us-central1).
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Defina como "true" para apontar o app para o Firebase Emulator Suite local
# (firebase emulators:start) em vez do projeto de produção.
VITE_USE_FIREBASE_EMULATORS=false

# NUNCA coloque ANTHROPIC_API_KEY aqui — a chave de IA vive somente como
# secret das Cloud Functions (functions/.env para o emulador, ou
# `firebase functions:secrets:set ANTHROPIC_API_KEY` em produção).
