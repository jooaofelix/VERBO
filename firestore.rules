rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOwnerFields(userId) {
      return request.resource.data.userId == userId
        && request.resource.data.keys().hasAll(['userId', 'createdAt', 'updatedAt']);
    }

    // ---- users/{userId} — profile document ----
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'email', 'photoURL', 'updatedAt']);
      allow delete: if isOwner(userId);

      // ---- users/{userId}/songs/{songId} ----
      match /songs/{songId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && hasOwnerFields(userId)
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 300;
        allow update: if isOwner(userId)
          && request.resource.data.userId == resource.data.userId
          && (!('title' in request.resource.data) || request.resource.data.title.size() <= 300);
        allow delete: if isOwner(userId);

        // ---- .../versions/{versionId} ----
        match /versions/{versionId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && hasOwnerFields(userId)
            && request.resource.data.lyrics is string
            && request.resource.data.lyrics.size() <= 20000;
          allow update: if isOwner(userId)
            && request.resource.data.userId == resource.data.userId
            && (!('lyrics' in request.resource.data) || request.resource.data.lyrics.size() <= 20000);
          allow delete: if isOwner(userId);
        }

        // ---- .../analyses/{analysisId} ----
        // There is no trusted server in this MVP (no Cloud Functions): the
        // Cloudflare Worker that runs the AI analysis never touches
        // Firestore, so the authenticated owner writes the result directly,
        // the same way it writes songs/versions. Isolation is still fully
        // enforced — nobody but the owner can read or write their analyses.
        match /analyses/{analysisId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && hasOwnerFields(userId)
            && request.resource.data.keys().hasAll(['versionId', 'mode', 'result']);
          allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isOwner(userId);
        }

        // ---- .../references/{referenceId} — user's own saved/favorited references ----
        match /references/{referenceId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && hasOwnerFields(userId)
            && request.resource.data.referenceLabel is string
            && request.resource.data.referenceLabel.size() <= 200;
          allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isOwner(userId);
        }

        // ---- .../comments/{commentId} ----
        match /comments/{commentId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && hasOwnerFields(userId)
            && request.resource.data.text is string
            && request.resource.data.text.size() <= 5000;
          allow update: if isOwner(userId)
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.text.size() <= 5000;
          allow delete: if isOwner(userId);
        }
      }

      // ---- users/{userId}/settings/{documentId} ----
      match /settings/{documentId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // ---- users/{userId}/reports/{reportId} ----
      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasOwnerFields(userId);
        allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }

    // Everything else is private by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
