# Porta HTTP do servidor.
PORT=8787

# Chave de API da Anthropic (Claude). Sem esta variável, o servidor roda em
# MODO DEMONSTRAÇÃO: as respostas de análise têm a mesma estrutura de uma
# análise real, mas o conteúdo é um exemplo fixo, claramente identificado.
# Obtenha uma chave em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Modelo Claude a usar para a análise. Padrão: claude-sonnet-5.
ANTHROPIC_MODEL=claude-sonnet-5

# Origem permitida para CORS (URL do front-end). Use "*" em desenvolvimento
# local; em produção, defina a URL exata do site publicado.
CORS_ORIGIN=*
